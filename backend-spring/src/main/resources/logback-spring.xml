<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <!-- 强制控制台输出使用 UTF-8，避免 Windows GBK 终端乱码 -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <charset>UTF-8</charset>
      <!-- traceId 来自 MDC，由 TraceIdFilter 在每个请求开始时写入 -->
      <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %5level [%X{traceId:-no-trace}] %22logger{22} : %msg%n</pattern>
    </encoder>
  </appender>

  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
  </root>
</configuration>
