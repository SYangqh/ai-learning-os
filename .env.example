# ─── AI Learning OS — 本地开发环境变量 ────────────────────────────────────────
# 复制此文件为 .env.local，填写你的真实值后启动后端。
# 后端读取方式：java -jar app.jar 前设置系统环境变量，或在 IDE Run Config 里配置。

# ── 数据库（与 docker-compose.yml 保持一致）──────────────────────────────────
DB_USERNAME=learningos
DB_PASSWORD=learningos

# ── Redis（默认无密码）────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# ── JWT（随机 256-bit base64，下面是示例，生产必须替换）────────────────────────
# 快速生成：openssl rand -base64 32
JWT_SECRET=CHANGE_ME_REPLACE_WITH_openssl_rand_base64_32_output

# ── AES-256-GCM 主密钥（格式：keyId:base64(32bytes)）────────────────────────
# 快速生成：python3 -c "import os,base64; print('dev-key-1:'+base64.b64encode(os.urandom(32)).decode())"
APP_ENCRYPTION_KEYS=dev-key-1:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
APP_ENCRYPTION_ACTIVE_KEY_ID=dev-key-1

# ── 邮件（魔法链接，可先留空；跳过邮件登录直接用游客模式）──────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@learningos.dev

# ── 前端地址（CORS + 邮件链接生成）────────────────────────────────────────────
FRONTEND_BASE_URL=http://localhost:3000
